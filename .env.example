# Cesium 3D Mapping (get free token from https://cesium.com/ion/signup)
VITE_CESIUM_ION_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJqdGkiOiIyZDJiNjI3ZC02MDM5LTRmMWYtODMyNS0yZThiNDBjOGU0M2IiLCJpZCI6MzM3MzUxLCJpYXQiOjE3NTY3NzM5NTd9.KeHD1KmmXeI0ONWN-PKuVnjirAUzfxJ33aRgi5d0AUg

# Environment
NODE_ENV=development

# Backend-only environment variables (not prefixed with VITE_)
