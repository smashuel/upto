# PostgreSQL — local connection on the Linode VPS
DATABASE_URL=postgresql://upto_user:password@localhost:5432/upto_db

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://172.105.178.48/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
BACKEND_URL=http://172.105.178.48

# Note: Frontend API keys (VITE_ prefixed) will be visible in the browser
# Make sure to use restricted keys with domain limitations in production